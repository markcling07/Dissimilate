 * The structure itself is the AEO pattern to keep:
 *  - TL;DR block first (engines lift self-contained summaries)
 *  - question-shaped H2s, each answered in the first sentence below it
 *  - lists for anything enumerable
 *  - blockquote for the one line you'd want an AI to quote verbatim
 */
import EssayLayout from '../layouts/EssayLayout.astro';
import ExpandableAside from '../components/ExpandableAside.tsx';

const meta = {
