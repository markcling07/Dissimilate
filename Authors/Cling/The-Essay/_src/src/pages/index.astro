const meta = {
  title: 'Investment in General Santos & Sarangani, still worth it?',
  // WORKING DESCRIPTION — feeds meta + JSON-LD. Confirm or replace.
  description:
    'After the June 2026 earthquake devastated General Santos City and Sarangani, one resident counts the economic cost to workers and vendors — and asks whether business and capital are still worth pouring into the region.',
