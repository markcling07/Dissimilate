---
/**
 * The AEO essay template for Dissimilate.
 *
 * Everything AI crawlers need is rendered statically here: the full text,
 * Article JSON-LD, OG/Twitter meta, semantic structure. React islands are
 * decoration on top — the page must read complete with JS disabled.
 */
interface Props {
  title: string;
  description: string;
  /** Absolute, percent-encoded URL of this page (trailing slash). */
  canonicalUrl: string;
  /** Absolute URL of the 1200×630 OG card. */
  ogImage: string;
  author: string;
  /** ISO date, e.g. "2026-07-15" */
  datePublished: string;
  dateModified?: string;
  /** Human-readable date shown in the byline. */
  displayDate: string;
  category: string;
  readTime: string;
}

const p = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: p.title,
  description: p.description,
  author: {
    '@type': 'Person',
    name: p.author,
    url: 'https://markcling07.github.io/Dissimilate/Authors/Cling/',
  },
  datePublished: p.datePublished,
  dateModified: p.dateModified ?? p.datePublished,
  image: p.ogImage,
  mainEntityOfPage: p.canonicalUrl,
  publisher: {
    '@type': 'Organization',
    name: 'Dissimilate',
    url: 'https://markcling07.github.io/Dissimilate/',
  },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{p.title} — Dissimilate</title>
    <meta name="description" content={p.description} />
    <link rel="canonical" href={p.canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={p.canonicalUrl} />
    <meta property="og:title" content={`${p.title} — Dissimilate`} />
    <meta property="og:description" content={p.description} />
    <meta property="og:image" content={p.ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="article:author" content={p.author} />
    <meta property="article:published_time" content={p.datePublished} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${p.title} — Dissimilate`} />
    <meta name="twitter:description" content={p.description} />
    <meta name="twitter:image" content={p.ogImage} />

    <!-- Article structured data for search & AI engines -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter: the license-free stand-in for Stripe's "Söhne" grotesque.
         Light weights (300) for display, 400 body, up to 700 for labels. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="essay-page">
      <article>
        <header class="essay-header">
          {(p.category || p.readTime) && (
            <p class="kicker">
              {p.category && <span>{p.category}</span>}
              {p.category && p.readTime && <span aria-hidden="true">·</span>}
              {p.readTime && <span>{p.readTime}</span>}
            </p>
          )}
          <h1 class="essay-title">{p.title}</h1>
          <p class="byline">
            By <a href="../">{p.author}</a> ·
            <time datetime={p.datePublished}>{p.displayDate}</time>
          </p>
        </header>

        <slot />
      </article>

      <footer class="essay-footer">
        <a class="back-btn" href="../../../index.html"><span>←</span> DISS</a>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --paper: #faf8f4;
    --ink: #1f2328;
    --ink-soft: rgba(31, 35, 40, 0.72);
    --accent: #4f63d8;
    --accent-deep: #3f51bd;
    --accent-soft: #e7ebfb;
    --rule: rgba(31, 35, 40, 0.14);
    --shadow-sm: 0 6px 20px rgba(40, 50, 120, 0.08);
    --radius: 12px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: 'Inter', -apple-system, 'SF Pro Display', sans-serif;
    color: var(--ink);
    background: var(--paper);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.011em;
  }

  body {
    line-height: 1.6;
  }

  .essay-page {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(3rem, 8vw, 5.5rem) clamp(1.25rem, 5vw, 2rem);
  }

  .essay-header {
    margin-bottom: 2.5rem;
  }

  .kicker {
    display: flex;
    gap: 0.6rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 1rem;
  }

  .essay-title {
    font-family: 'Inter', -apple-system, 'SF Pro Display', sans-serif;
    font-size: clamp(2.3rem, 6vw, 3.6rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
  }

  .byline {
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  .byline a {
    color: var(--accent-deep);
    font-weight: 700;
    text-decoration: none;
  }

  .byline a:hover {
    text-decoration: underline;
  }

  /* TL;DR — the answer-first block AI engines lift from */
  .tldr {
    background: var(--accent-soft);
    border-left: 4px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.1rem 1.4rem;
    margin: 0 0 2.75rem;
  }

  .tldr strong {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.35rem;
  }

  article h2 {
    font-family: 'Inter', -apple-system, 'SF Pro Display', sans-serif;
    font-size: clamp(1.5rem, 3.6vw, 2rem);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 2.75rem 0 1rem;
  }

  article p {
    margin-bottom: 1.25rem;
    color: var(--ink);
    font-size: 1.05rem;
  }

  article ul,
  article ol {
    margin: 0 0 1.25rem 1.4rem;
  }

  article li {
    margin-bottom: 0.4rem;
  }

  article figure {
    margin: 2rem 0;
  }

  article figure img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }

  article figcaption {
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin-top: 0.6rem;
    text-align: center;
  }

  article blockquote {
    font-family: 'Inter', -apple-system, 'SF Pro Display', sans-serif;
    font-weight: 300;
    font-size: 1.6rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 2.5rem 0;
    color: var(--ink);
  }

  /* ExpandableAside island (rendered by React, so styled globally here) */
  .aside-note {
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    margin: 2rem 0;
    background: rgba(79, 99, 216, 0.04);
  }

  .aside-toggle {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    font: inherit;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    padding: 0.9rem 1.25rem;
    cursor: pointer;
  }

  .aside-body {
    padding: 0 1.25rem 1rem;
  }

  .aside-body p {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin-bottom: 0;
  }

  .essay-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: center;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    border-radius: 999px;
    background: var(--ink);
    color: var(--paper);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.25s ease;
  }

  .back-btn:hover {
    background: var(--accent-deep);
  }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 3px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
